pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/srikanth-girimaiahgari/devops-demo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-demo:1.0 .'
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker tag devops-demo gsrikanth14/devops-demo'
                sh 'docker push gsrikanth14/devops-demo'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f deployment.yaml'
            }
        }

    }
}